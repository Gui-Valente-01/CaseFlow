# =====================================================================
# CaseFlow — variáveis de ambiente
# Copie para `.env.local` e preencha. NUNCA comite `.env.local`.
# Legenda:  [OBRIGATÓRIA] = sem ela o app não sobe/funciona em produção
#           [OPCIONAL]    = recurso desliga sozinho de forma segura se faltar
# =====================================================================

# --- Supabase (banco, auth, storage) ------------------------- [OBRIGATÓRIA]
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# --- URL pública do site ------------------------------------- [OBRIGATÓRIA]
# Usada em links de e-mail, callbacks e metadados. Em produção, a URL real.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- E-mail transacional (Resend) ------------------ [OPCIONAL p/ dev, OBRIG. p/ prod]
# Sem RESEND_API_KEY o envio de e-mail é desligado (convites/recuperação não saem).
# EMAIL_FROM precisa ser um remetente de um domínio verificado no Resend —
# o placeholder abaixo NÃO funciona em produção.
RESEND_API_KEY=
EMAIL_FROM="CaseFlow <noreply@seudominio.com>"

# --- Billing / Promoção de lançamento ------------------------ [OPCIONAL]
# Controla o "modo grátis no lançamento". Ausente ou qualquer valor != "false"
# => sistema GRATUITO (ninguém é bloqueado, landing anuncia grátis).
# Para VOLTAR A COBRAR, defina exatamente `false` e refaça o deploy.
# (server-only de propósito — não exponha como NEXT_PUBLIC.)
BILLING_PAUSED=

# --- Sentry (monitoramento de erros) ------------------------- [OPCIONAL]
# Sem DSN, a captura de erros vira no-op (o app funciona normalmente).
# Recomendado em produção. SENTRY_AUTH_TOKEN só é necessário para subir
# sourcemaps no build (CI).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# --- Stripe (checkout automático) ---------------------------- [OPCIONAL]
# Sem as chaves, o checkout automático fica indisponível e o app cai no
# pagamento manual (PIX). Necessário só quando for cobrar via Stripe.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_ESSENTIAL=

# --- Integração DataJud (CNJ) -------------------------------- [OPCIONAL]
# Consulta de andamentos por número de processo. Sem a chave, as consultas
# viram erro "não configurado" e o resto do app segue funcionando.
# Chave pública do CNJ: https://datajud-wiki.cnj.jus.br/api-publica/acesso
DATAJUD_API_KEY=

# --- Job agendado (/api/cron/sync-cases) --------------------- [OPCIONAL]
# Atualização automática diária dos andamentos. Sem CRON_SECRET a rota fica
# desligada (501). Gere um valor aleatório forte.
CRON_SECRET=
